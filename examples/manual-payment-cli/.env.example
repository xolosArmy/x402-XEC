# Documentation-only placeholders. The CLI does not automatically load this file.
CHRONIK_URL=https://your-explicit-chronik.example
FROM_ADDRESS=ecash:replace_with_dedicated_test_wallet_address
PAY_TO_ADDRESS=ecash:replace_with_reviewed_recipient_address
